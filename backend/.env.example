# LLM Configuration
# Choose your provider: 'openai', 'gemini', or 'openai_compatible'
LLM_PROVIDER=openai

# Model to use: e.g. gpt-4o-mini, gemini-2.5-flash, llama3 (if Ollama)
LLM_MODEL=gpt-4o-mini

# API Keys (uncomment and set the one you need)
# For OpenAI:
OPENAI_API_KEY=your-openai-api-key-here
# For custom endpoints (Ollama, LM Studio):
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1

# For Google Gemini direct API:
# GEMINI_API_KEY=your-gemini-api-key-here

# Storage Configuration
# Inside Docker, this will automatically default to /SelfLearned_Data, 
# which is volume-mounted to your host machine's directory.
# DATA_DIR=/SelfLearned_Data
